# Soul Hub — Environment Variables
# Most variables are OPTIONAL — core features work without them.
# Pipelines that require specific APIs will fail gracefully if keys are missing.
#
# Where to put values:
#   - Platform secrets are stored at ~/.soul-hub/.env and managed via the
#     Settings page. Anything you set here in .env (project root) is loaded
#     too, but ~/.soul-hub/.env wins on conflict. Prefer the home location.
#   - Override the home location with SOUL_HUB_HOME (e.g. for tests).

# ─── Server ───────────────────────────────────────────────
PORT=2400                          # HTTP server port (default: 2400)
# SOUL_HUB_HOME=~/.soul-hub        # Override the user-state directory
# SOUL_HUB_SETTINGS=               # Override the settings.json path

# ─── Required if you use the Unified Inbox ───────────────
# Generate once: node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
# Losing this value makes existing encrypted credentials unrecoverable — store it securely.
# SOUL_HUB_SECRET=

# ─── Google / Gemini ──────────────────────────────────────
# GOOGLE_API_KEY=                  # Google Cloud APIs (Geocoding, Places)
# GEMINI_API_KEY=                  # Gemini image generation + Veo video
# GOOGLE_CLIENT_ID=                # Gmail OAuth — manage via Settings UI (see INSTALL.md)
# GOOGLE_CLIENT_SECRET=            # Gmail OAuth — manage via Settings UI (see INSTALL.md)

# ─── AI / LLM ────────────────────────────────────────────
# ELEVENLABS_API_KEY=              # ElevenLabs text-to-speech
# HF_API_TOKEN=                    # Hugging Face Inference API

# ─── Social / Research ────────────────────────────────────
# APIDIRECT_API_KEY=               # Twitter, Reddit, TikTok, LinkedIn, News
# YOUTUBE_API_KEY=                 # YouTube Data API

# ─── Communication ────────────────────────────────────────
# RESEND_API_KEY=                  # Resend email sending
# TELEGRAM_BOT_TOKEN=             # Telegram bot notifications
# TELEGRAM_CHAT_ID=               # Telegram chat for notifications

# ─── Project Management ──────────────────────────────────
# LINEAR_API_KEY=                  # Linear issue tracking integration
