# @xterm/addon-canvas@0.7 peer-wants @xterm/xterm@^5 while the project pins
# @xterm/xterm@6. The resolution is safe (addon-canvas is API-compatible), so
# accept it instead of forcing a downgrade. Required for a clean `npm install`
# / `npm ci` on a fresh checkout — without it a fresh install fails ERESOLVE.
legacy-peer-deps=true
